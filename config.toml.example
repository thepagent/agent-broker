[discord]
bot_token = "${DISCORD_BOT_TOKEN}"
allowed_channels = ["1234567890"]

# ── Telegram (alternative to Discord) ───────────────────────────────────────
# [telegram]
# bot_token = "${TELEGRAM_BOT_TOKEN}"
# allowed_users = [123456789]          # required: your Telegram user ID (bot won't start without this)
#
# # Chat mode — choose one:
# #
# #   personal (default):
# #     Any message in #general/All auto-creates a new topic.
# #     Inside topics, Kiro replies to every message directly.
# #     Best for: single user or private bot usage.
# #
# #   team:
# #     In #general/All:
# #       - plain messages → Kiro listens silently (👀), buffers context, no reply.
# #       - @mention → Kiro replies in-place (no topic created).
# #       - `!kiro <prompt>` → creates a new topic (restricted to topic_creator_id if set).
# #     Inside topics:
# #       - plain messages → Kiro listens silently (👀), buffers context, no reply.
# #       - @mention → Kiro replies directly.
# #     Best for: community/team group chats with multiple users.
# #
# mode = "personal"
# topic_creator_id = 123456789   # team mode only: who can run !kiro

[agent]
command = "kiro-cli"
args = ["acp", "--trust-all-tools"]
working_dir = "/home/agent"

# MCP servers to expose to the agent on each session.
# If omitted, the agent uses its own default MCP config (e.g. ~/.kiro/mcp.json).
# Defining servers here overrides that — list every server you want available.
#
# Example: markitdown for document/file reading
# [[agent.mcp_servers]]
# name = "markitdown"
# command = "python3"
# args = ["/path/to/markitdown-agent/server.py"]

# [agent]
# command = "claude"
# args = ["--acp"]
# working_dir = "/home/agent"
# env = { ANTHROPIC_API_KEY = "${ANTHROPIC_API_KEY}" }

# [agent]
# command = "codex"
# args = ["--acp"]
# working_dir = "/home/agent"
# env = { OPENAI_API_KEY = "${OPENAI_API_KEY}" }

# [agent]
# command = "gemini"
# args = ["--acp"]
# working_dir = "/home/agent"
# env = { GEMINI_API_KEY = "${GEMINI_API_KEY}" }

[pool]
max_sessions = 10
session_ttl_hours = 24
crash_history_size = 20  # number of recent user messages to keep for crash recovery (0 to disable)

[reactions]
enabled = true
remove_after_reply = false

[reactions.emojis]
queued = "👀"
thinking = "🤔"
tool = "🔥"
coding = "👨💻"
web = "⚡"
done = "🆗"
error = "😱"

[reactions.timing]
debounce_ms = 700
stall_soft_ms = 10000
stall_hard_ms = 30000
done_hold_ms = 1500
error_hold_ms = 2500
